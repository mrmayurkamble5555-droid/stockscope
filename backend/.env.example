# ─── Database (Supabase) ─────────────────────────────────────────────────────
# Get from: Supabase → Settings → Database → Connection String → URI
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.YOURPROJECT.supabase.co:5432/postgres


# ─── Redis (Upstash) ──────────────────────────────────────────────────────────
# Get from: Upstash → Your Database → REDIS_URL
REDIS_URL=rediss://default:YOUR_TOKEN@YOUR_HOST.upstash.io:6379


# ─── Typesense (Search) ───────────────────────────────────────────────────────
# Get from: cloud.typesense.org → Your Cluster
TYPESENSE_HOST=YOUR_CLUSTER.a1.typesense.net
TYPESENSE_PORT=443
TYPESENSE_PROTOCOL=https
TYPESENSE_API_KEY=YOUR_ADMIN_API_KEY


# ─── Indian Stock Market API (free data source) ───────────────────────────────
# Base URL for the open-source Indian-Stock-Market-API
INDIAN_STOCK_API_BASE=https://stock.indianapi.in


# ─── App ──────────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development


# ─── NSE Headers (do not change) ─────────────────────────────────────────────
NSE_REFERER=https://www.nseindia.com
NSE_USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/122.0.0.0 Safari/537.36
